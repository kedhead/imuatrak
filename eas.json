{
  "cli": { "version": ">= 13.0.0", "appVersionSource": "remote" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "node": "20.19.0",
      "ios": { "simulator": true, "image": "latest" },
      "android": { "buildType": "apk" }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "node": "20.19.0",
      "ios": { "image": "latest" },
      "android": { "buildType": "apk" }
    },
    "production": {
      "channel": "production",
      "node": "20.19.0",
      "autoIncrement": true,
      "ios": { "image": "latest" }
    }
  },
  "submit": {
    "production": {}
  }
}
