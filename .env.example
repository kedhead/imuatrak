# Copy to .env and fill in from your Firebase web-app config.
# These are PUBLIC values (Firebase web SDK keys are not secrets) but we
# still keep them out of git so dev/prod projects don't get mixed up.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
# Newer Firebase projects use the <project>.firebasestorage.app domain,
# NOT <project>.appspot.com. Copy the exact value from your Firebase config.
# e.g. imuatrak.firebasestorage.app
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Android only — get from Google Cloud Console > APIs > Credentials.
# Restrict the key to "Maps SDK for Android" + your app's package name +
# debug+release SHA-1 fingerprints. iOS uses Apple Maps, no key needed.
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=

# AdMob — build-time app IDs (used by the config plugin) and runtime ad unit IDs.
# Get these from your Google AdMob account (admob.google.com).
# During development the app falls back to Google's official test IDs automatically.
ADMOB_IOS_APP_ID=ca-app-pub-xxxxxxxxxxxxxxxx~xxxxxxxxxx
ADMOB_ANDROID_APP_ID=ca-app-pub-xxxxxxxxxxxxxxxx~xxxxxxxxxx
EXPO_PUBLIC_ADMOB_BANNER_UNIT_ID_IOS=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx
EXPO_PUBLIC_ADMOB_BANNER_UNIT_ID_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx

# RevenueCat — separate public keys for iOS and Android.
# Get these from your RevenueCat dashboard (app.revenuecat.com > Project > API keys).
# Create an entitlement called "ad_free" and attach your subscription product to it.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
