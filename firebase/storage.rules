rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid}/tracks/{file} {
      allow read, write: if isOwner(uid)
        && (file.matches('.*\\.gpx$') || file.matches('.*\\.fit$'))
        && request.resource.size < 25 * 1024 * 1024;
    }

    match /users/{uid}/cards/{file} {
      // Cards are written by the renderSessionCard Cloud Function.
      allow read: if isOwner(uid);
      allow write: if false;
    }

    match /clubs/{clubId}/logo.jpg {
      // Any signed-in user can read club logos (public resource).
      // Writes are restricted to small images so logos can't be used for storage abuse.
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType == 'image/jpeg';
    }
  }
}
