rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Cross-service lookups against Firestore membership docs. Storage rules
    // can't see club roles directly, so we consult clubs/{clubId}/members.
    function isClubMember(clubId) {
      return request.auth != null &&
        firestore.exists(/databases/(default)/documents/clubs/$(clubId)/members/$(request.auth.uid));
    }

    function isClubAdmin(clubId) {
      return request.auth != null &&
        firestore.get(/databases/(default)/documents/clubs/$(clubId)/members/$(request.auth.uid)).data.role in ['owner', 'admin'];
    }

    match /users/{uid}/tracks/{file} {
      allow read, write: if isOwner(uid)
        && (file.matches('.*\\.gpx$') || file.matches('.*\\.fit$'))
        && request.resource.size < 25 * 1024 * 1024;
    }

    match /users/{uid}/cards/{file} {
      // Cards are written by the renderSessionCard Cloud Function.
      allow read: if isOwner(uid);
      allow write: if false;
    }

    match /clubs/{clubId}/messages/{messageId}/{file} {
      allow read: if isClubMember(clubId);
      allow write: if isClubMember(clubId)
        && request.resource.size < 100 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType.matches('video/.*'));
    }

    // Channel-scoped message media — the path actually used by
    // clubService.uploadMessageMedia. Without this the legacy /messages rule
    // above never matches the channels/ path and uploads are denied.
    // Known limitation: private-channel media is readable by any club member
    // (Storage rules can't cheaply check channel memberIds); the message docs
    // that reveal these paths remain channel-member-only in Firestore.
    match /clubs/{clubId}/channels/{channelId}/messages/{messageId}/{file} {
      allow read: if isClubMember(clubId);
      allow write: if isClubMember(clubId)
        && request.resource.size < 100 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType.matches('video/.*'));
      // Deleting a message cleans up its media. The write rule above can't
      // cover delete (no request.resource on a delete), so allow it explicitly
      // for club members. Firestore rules still gate WHO can delete the message
      // doc (author or owner/admin), which is what drives this cleanup.
      allow delete: if isClubMember(clubId);
    }

    match /clubs/{clubId}/logo.jpg {
      // Any signed-in user can read club logos (public resource).
      // Only club owners/admins may replace a club's logo; size/type limits
      // keep logos from being used for storage abuse.
      allow read: if request.auth != null;
      allow write: if isClubAdmin(clubId)
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType == 'image/jpeg';
    }
  }
}
