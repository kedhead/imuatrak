rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isClubMember(clubId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid));
    }

    function getClubMember(clubId) {
      return get(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid)).data;
    }

    function hasClubRole(clubId, roles) {
      return isClubMember(clubId) && getClubMember(clubId).role in roles;
    }

    // ── User sessions (private) ──────────────────────────────────────────────
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /sessions/{sessionId} {
        allow read: if isOwner(uid);

        allow create: if isOwner(uid)
          && request.resource.data.userId == uid
          && request.resource.data.schemaVersion is int;

        allow update: if isOwner(uid)
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.schemaVersion == resource.data.schemaVersion;

        allow delete: if isOwner(uid);
      }
    }

    // Public-shared sessions (powers imuatrak.app/s/{id}). The phone app
    // writes a denormalized copy here when the user toggles "Share
    // publicly" on, and deletes it when they toggle it off.
    //
    // Anyone can read, only the original owner can write.
    match /publicSessions/{sessionId} {
      allow read: if true;

      allow create, update: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.isPublic == true;

      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    // ── User → club membership index ─────────────────────────────────────────
    match /userClubs/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ── Invite tokens (created by Cloud Functions, read by any signed-in user)
    match /clubInvites/{token} {
      allow read: if isSignedIn();
      allow write: if false; // Cloud Functions only
    }

    // ── Clubs ────────────────────────────────────────────────────────────────
    match /clubs/{clubId} {
      // Members get full read access. Any signed-in user can read basic club
      // metadata so they can preview a club before joining via a slug link.
      allow read: if isSignedIn();
      allow update: if hasClubRole(clubId, ["owner", "admin"]);
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow delete: if hasClubRole(clubId, ["owner"]);

      // ── Members ────────────────────────────────────────────────────────────
      match /members/{uid} {
        allow read: if isClubMember(clubId);
        allow write: if hasClubRole(clubId, ["owner", "admin"]);
        // Users can create/delete their own membership (join via invite, leave).
        allow create, delete: if isOwner(uid);
      }

      // ── Events ─────────────────────────────────────────────────────────────
      match /events/{eventId} {
        allow read: if isClubMember(clubId);
        allow create, update: if hasClubRole(clubId, ["owner", "admin", "coach"]);
        allow delete: if hasClubRole(clubId, ["owner", "admin"]);
      }

      // ── Chat messages ──────────────────────────────────────────────────────
      match /messages/{messageId} {
        allow read: if isClubMember(clubId);
        allow create: if isClubMember(clubId)
          && request.resource.data.authorId == request.auth.uid;
        allow delete: if isClubMember(clubId)
          && (resource.data.authorId == request.auth.uid
              || hasClubRole(clubId, ["owner", "admin"]));
        allow update: if false;
      }

      // ── Posts ──────────────────────────────────────────────────────────────
      match /posts/{postId} {
        allow read: if isClubMember(clubId);
        allow create: if isClubMember(clubId)
          && request.resource.data.authorId == request.auth.uid;
        allow update: if isClubMember(clubId)
          && (resource.data.authorId == request.auth.uid
              || hasClubRole(clubId, ["owner", "admin"]));
        allow delete: if isClubMember(clubId)
          && (resource.data.authorId == request.auth.uid
              || hasClubRole(clubId, ["owner", "admin"]));

        // ── Comments ─────────────────────────────────────────────────────────
        match /comments/{commentId} {
          allow read: if isClubMember(clubId);
          allow create: if isClubMember(clubId)
            && request.resource.data.authorId == request.auth.uid;
          allow update: if isClubMember(clubId)
            && resource.data.authorId == request.auth.uid;
          allow delete: if isClubMember(clubId)
            && (resource.data.authorId == request.auth.uid
                || hasClubRole(clubId, ["owner", "admin"]));
        }
      }
    }
  }
}
