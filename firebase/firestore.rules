rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // User profile + private sessions — owner only.
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /sessions/{sessionId} {
        allow read: if isOwner(uid);

        allow create: if isOwner(uid)
          && request.resource.data.userId == uid
          && request.resource.data.schemaVersion is int;

        allow update: if isOwner(uid)
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.schemaVersion == resource.data.schemaVersion;

        allow delete: if isOwner(uid);
      }
    }

    // Public-shared sessions (powers imuatrak.app/s/{id}). The phone app
    // writes a denormalized copy here when the user toggles "Share
    // publicly" on, and deletes it when they toggle it off.
    //
    // Anyone can read, only the original owner can write.
    match /publicSessions/{sessionId} {
      allow read: if true;

      allow create, update: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.isPublic == true;

      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }
  }
}
