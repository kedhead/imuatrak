rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isClubMember(clubId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid));
    }

    function getClubMember(clubId) {
      return get(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid)).data;
    }

    function hasClubRole(clubId, roles) {
      return isClubMember(clubId) && getClubMember(clubId).role in roles;
    }

    // ── User sessions (private) ──────────────────────────────────────────────
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /fcmTokens/{tokenId} {
        allow read, write: if isOwner(uid);
      }

      match /channelPreferences/{channelId} {
        allow read, write: if isOwner(uid);
      }

      match /sessions/{sessionId} {
        allow read: if isOwner(uid);

        allow create: if isOwner(uid)
          && request.resource.data.userId == uid
          && request.resource.data.schemaVersion is int;

        allow update: if isOwner(uid)
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.schemaVersion == resource.data.schemaVersion;

        allow delete: if isOwner(uid);
      }
    }

    // Public-shared sessions (powers imuatrak.app/s/{id}). The phone app
    // writes a denormalized copy here when the user toggles "Share
    // publicly" on, and deletes it when they toggle it off.
    //
    // Anyone can read, only the original owner can write.
    match /publicSessions/{sessionId} {
      allow read: if true;

      allow create, update: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.isPublic == true;

      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    // ── User → club membership index ─────────────────────────────────────────
    match /userClubs/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ── App admins ───────────────────────────────────────────────────────────
    // Grants access to the app-analytics admin page (imuatrak.app/dashboard/
    // admin). Docs are created manually in the Firebase console: doc ID = the
    // admin's Auth UID. A user may check their OWN admin status so the web
    // dashboard knows whether to show the page; the getAppStats Cloud Function
    // re-checks server-side, so this read is a UI hint, not the gate.
    match /admins/{uid} {
      allow get: if isOwner(uid);
      allow list, write: if false; // console / Admin SDK only
    }

    // ── Invite tokens (created by Cloud Functions) ───────────────────────────
    // Tokens are secret capabilities: a signed-in user who KNOWS a token may
    // fetch it (join flow does a direct doc get), but nobody may list the
    // collection — otherwise any user could enumerate tokens and self-join
    // every club.
    match /clubInvites/{token} {
      allow get: if isSignedIn();
      allow list: if false;
      allow write: if false; // Cloud Functions only
    }

    // ── Clubs ────────────────────────────────────────────────────────────────
    match /clubs/{clubId} {
      // The club document holds only non-sensitive metadata (name, logo,
      // location, member count). It is publicly readable so invite links and
      // the imuatrak.app/join landing page can show which club you're joining
      // before sign-in. All sub-collections below keep their stricter rules.
      allow read: if true;
      // Owners/admins can edit the club. memberCount is maintained solely by
      // the onMemberJoin/onMemberLeave Cloud Function triggers (Admin SDK
      // bypasses rules), so clients get no counter carve-out — it allowed any
      // signed-in user to set an arbitrary count on any club.
      // Subscription fields are billing state (they gate ads and channel
      // limits) and may only change server-side: the expireClubTrials sweep
      // and any future billing webhook, both via the Admin SDK.
      allow update: if hasClubRole(clubId, ["owner", "admin"])
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(
          ["subscriptionStatus", "subscriptionTier", "trialEndsAt", "subscriptionRenewsAt"]
        );
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow delete: if hasClubRole(clubId, ["owner"]);

      // ── Members ────────────────────────────────────────────────────────────
      match /members/{uid} {
        // A member can read the roster; anyone may read THEIR OWN member doc
        // even before joining, so the join flow's "am I already a member?"
        // existence check isn't denied for a brand-new joiner. isOwner(uid)
        // restricts this to the caller's own doc — no enumerating others.
        allow read: if isClubMember(clubId) || isOwner(uid);
        // Users can create/delete their own membership (join via invite, leave).
        allow create, delete: if isOwner(uid) || hasClubRole(clubId, ["owner", "admin"]);
        // Owners/admins can update any member (e.g. change role). A member may
        // update THEIR OWN doc only for profile fields (displayName/avatarUrl) —
        // role and uid must be unchanged, so they can't self-promote.
        allow update: if hasClubRole(clubId, ["owner", "admin"])
          || (isOwner(uid)
              && request.resource.data.role == resource.data.role
              && request.resource.data.uid == resource.data.uid);
      }

      // ── Events ─────────────────────────────────────────────────────────────
      match /events/{eventId} {
        allow read: if isClubMember(clubId);
        allow create, update: if hasClubRole(clubId, ["owner", "admin", "coach"]);
        allow delete: if hasClubRole(clubId, ["owner", "admin"]);
      }

      // ── Legacy chat messages (kept readable during migration) ─────────────
      match /messages/{messageId} {
        allow read: if isClubMember(clubId);
        allow create, update: if false;
        allow delete: if isClubMember(clubId)
          && (resource.data.authorId == request.auth.uid
              || hasClubRole(clubId, ["owner", "admin"]));
      }

      // ── Channels ───────────────────────────────────────────────────────────
      match /channels/{channelId} {
        function isChannelMember() {
          let ch = get(/databases/$(database)/documents/clubs/$(clubId)/channels/$(channelId)).data;
          return !ch.isPrivate
            ? isClubMember(clubId)
            : (isClubMember(clubId) && request.auth.uid in ch.memberIds)
              || hasClubRole(clubId, ["owner", "admin"]);
        }

        // All club members can see the channel list (name/icon/isPrivate)
        allow read: if isClubMember(clubId);
        // Channel creation goes through Cloud Function (Admin SDK) — deny direct writes
        allow create: if false;
        allow update, delete: if hasClubRole(clubId, ["owner", "admin"]);

        match /messages/{messageId} {
          allow read: if isChannelMember();
          allow create: if isChannelMember()
            && request.resource.data.authorId == request.auth.uid;
          allow delete: if isChannelMember()
            && (resource.data.authorId == request.auth.uid
                || hasClubRole(clubId, ["owner", "admin"]));
          // Members may toggle emoji reactions — and touch NOTHING else on the
          // message (same affectedKeys pattern as poll votes on posts).
          allow update: if isChannelMember()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["reactions"]);
        }
      }

      // ── Posts ──────────────────────────────────────────────────────────────
      match /posts/{postId} {
        allow read: if isClubMember(clubId);
        allow create: if isClubMember(clubId)
          && request.resource.data.authorId == request.auth.uid;
        allow update: if isClubMember(clubId)
          && (resource.data.authorId == request.auth.uid
              || hasClubRole(clubId, ["owner", "admin"])
              || (resource.data.type == "poll"
                  && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["pollVotes"])));
        allow delete: if isClubMember(clubId)
          && (resource.data.authorId == request.auth.uid
              || hasClubRole(clubId, ["owner", "admin"]));

        // ── Comments ─────────────────────────────────────────────────────────
        match /comments/{commentId} {
          allow read: if isClubMember(clubId);
          allow create: if isClubMember(clubId)
            && request.resource.data.authorId == request.auth.uid;
          allow update: if isClubMember(clubId)
            && resource.data.authorId == request.auth.uid;
          allow delete: if isClubMember(clubId)
            && (resource.data.authorId == request.auth.uid
                || hasClubRole(clubId, ["owner", "admin"]));
        }
      }
    }
  }
}
